<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="mycobot_280" params="parent prefix *origin">

    <!-- 将父 link 连接到机械臂基座 -->
    <joint name="${prefix}g_base_joint" type="fixed">
      <xacro:insert_block name="origin" />
      <parent link="${parent}"/>
      <child link="${prefix}g_base"/>
    </joint>

    <!-- 基座 link -->
    <link name="${prefix}g_base">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/G_base.dae"/>
        </geometry>
        <origin xyz="0.0 0 -0.03" rpy="0 0 1.5708"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/G_base.dae"/>
        </geometry>
        <origin xyz="0.0 0 -0.03" rpy="0 0 1.5708"/>
      </collision>
    </link>

    <!-- joint1 -->
    <link name="${prefix}joint1">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/g_base_simple.stl"/>
        </geometry>
        <origin xyz="0.0 0 0" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/g_base_simple.stl"/>
        </geometry>
        <origin xyz="0.0 0 0" rpy="0 0 0"/>
      </collision>
    </link>

    <joint name="${prefix}g_base_to_joint1" type="fixed">
      <axis xyz="0 0 0"/>
      <limit effort="1000.0" lower="-3.14" upper="3.14159" velocity="0"/>
      <parent link="${prefix}g_base"/>
      <child link="${prefix}joint1"/>
      <origin xyz="0 0 0" rpy="0 0 0"/>
    </joint>

    <!-- joint2 -->
    <link name="${prefix}joint2">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/joint2.dae"/>
        </geometry>
        <origin xyz="0.0 0 -0.06096" rpy="0 0 -1.5708"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/joint2.dae"/>
        </geometry>
        <origin xyz="0.0 0 -0.06096" rpy="0 0 -1.5708"/>
      </collision>
    </link>

    <joint name="${prefix}joint2_to_joint1" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000.0" lower="-2.9321" upper="2.9321" velocity="0"/>
      <parent link="${prefix}joint1"/>
      <child link="${prefix}joint2"/>
      <origin xyz="0 0 0.13956" rpy="0 0 0"/>
    </joint>

    <!-- joint3 -->
    <link name="${prefix}joint3">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/joint3.dae"/>
        </geometry>
        <origin xyz="0.0 0 0.03256" rpy="0 -1.5708 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/joint3.dae"/>
        </geometry>
        <origin xyz="0.0 0 0.03256" rpy="0 -1.5708 0"/>
      </collision>
    </link>

    <joint name="${prefix}joint3_to_joint2" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000.0" lower="-2.4434" upper="2.4434" velocity="0"/>
      <parent link="${prefix}joint2"/>
      <child link="${prefix}joint3"/>
      <origin xyz="0 0 -0.001" rpy="0 1.5708 -1.5708"/>
    </joint>

    <!-- joint4 -->
    <link name="${prefix}joint4">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/joint4.dae"/>
        </geometry>
        <origin xyz="0.0 0 0.03056" rpy="0 -1.5708 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/joint4.dae"/>
        </geometry>
        <origin xyz="0.0 0 0.03056" rpy="0 -1.5708 0"/>
      </collision>
    </link>

    <joint name="${prefix}joint4_to_joint3" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000.0" lower="-2.6179" upper="2.6179" velocity="0"/>
      <parent link="${prefix}joint3"/>
      <child link="${prefix}joint4"/>
      <origin xyz="-0.1104 0 0" rpy="0 0 0"/>
    </joint>

    <!-- joint5 -->
    <link name="${prefix}joint5">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/J5_simple.stl"/>
        </geometry>
        <origin xyz="-0.02 0.002 0" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/J5_simple.stl"/>
        </geometry>
        <origin xyz="-0.02 0.002 0" rpy="0 0 0"/>
      </collision>
    </link>

    <joint name="${prefix}joint5_to_joint4" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000.0" lower="-2.6179" upper="2.6179" velocity="0"/>
      <parent link="${prefix}joint4"/>
      <child link="${prefix}joint5"/>
      <origin xyz="-0.096 0 0.06462" rpy="0 0 -1.5708"/>
    </joint>

    <!-- joint6 -->
    <link name="${prefix}joint6">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/joint6.dae"/>
        </geometry>
        <origin xyz="0 0.00 -0.038" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/joint6.dae"/>
        </geometry>
        <origin xyz="0 0.00 -0.038" rpy="0 0 0"/>
      </collision>
    </link>

    <joint name="${prefix}joint6_to_joint5" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000.0" lower="-2.7052" upper="2.7925" velocity="0"/>
      <parent link="${prefix}joint5"/>
      <child link="${prefix}joint6"/>
      <origin xyz="0 -0.07318 -0.001" rpy="1.5708 -1.5708 0"/>
    </joint>

    <!-- joint6 flange -->
    <link name="${prefix}joint6_flange">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/joint7.dae"/>
        </geometry>
        <origin xyz="0.0 0 -0.012" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/mycobot_280_pi/joint7.dae"/>
        </geometry>
        <origin xyz="0.0 0 -0.012" rpy="0 0 0"/>
      </collision>
    </link>

    <joint name="${prefix}joint6output_to_joint6" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000.0" lower="-3.14159" upper="3.14159" velocity="0"/>
      <parent link="${prefix}joint6"/>
      <child link="${prefix}joint6_flange"/>
      <origin xyz="0 0.0456 0" rpy="-1.5708 0 0"/>
    </joint>

    <!-- 夹爪部分 -->
    <link name="${prefix}gripper_base">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/adaptive_gripper/gripper_base.dae"/>
        </geometry>
        <origin xyz="0.0 0 -0.012" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/adaptive_gripper/gripper_base.dae"/>
        </geometry>
        <origin xyz="0.0 0 -0.012" rpy="0 0 0"/>
      </collision>
    </link>

    <joint name="${prefix}joint6output_to_gripper_base" type="fixed">
      <parent link="${prefix}joint6_flange"/>
      <child link="${prefix}gripper_base"/>
      <origin xyz="0 0 0.034" rpy="1.579 0 0"/>
    </joint>

    <link name="${prefix}gripper_left1">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/adaptive_gripper/gripper_left1.dae"/>
        </geometry>
        <origin xyz="0.039 -0.0133 -0.012" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/adaptive_gripper/gripper_left1.dae"/>
        </geometry>
        <origin xyz="0.039 -0.0133 -0.012" rpy="0 0 0"/>
      </collision>
    </link>

    <link name="${prefix}gripper_left2">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/adaptive_gripper/gripper_left2.dae"/>
        </geometry>
        <origin xyz="0.005 -0.0195 -0.012" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/adaptive_gripper/gripper_left2.dae"/>
        </geometry>
        <origin xyz="0.005 -0.0195 -0.012" rpy="0 0 0"/>
      </collision>
    </link>

    <link name="${prefix}gripper_left3">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/adaptive_gripper/gripper_left3.dae"/>
        </geometry>
        <origin xyz="0.012 0.0025 -0.012" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/adaptive_gripper/gripper_left3.dae"/>
        </geometry>
        <origin xyz="0.012 0.0025 -0.012" rpy="0 0 0"/>
      </collision>
    </link>

    <link name="${prefix}gripper_right1">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/adaptive_gripper/gripper_right1.dae"/>
        </geometry>
        <origin xyz="-0.039 -0.0133 -0.012" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/adaptive_gripper/gripper_right1.dae"/>
        </geometry>
        <origin xyz="-0.039 -0.0133 -0.012" rpy="0 0 0"/>
      </collision>
    </link>

    <link name="${prefix}gripper_right2">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/adaptive_gripper/gripper_right2.dae"/>
        </geometry>
        <origin xyz="-0.005 -0.0195 -0.012" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/adaptive_gripper/gripper_right2.dae"/>
        </geometry>
        <origin xyz="-0.005 -0.0195 -0.012" rpy="0 0 0"/>
      </collision>
    </link>

    <link name="${prefix}gripper_right3">
      <visual>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/adaptive_gripper/gripper_right3.dae"/>
        </geometry>
        <origin xyz="-0.012 0.0025 -0.012" rpy="0 0 0"/>
      </visual>
      <collision>
        <geometry>
          <mesh filename="package://mycobot_description/urdf/adaptive_gripper/gripper_right3.dae"/>
        </geometry>
        <origin xyz="-0.012 0.0025 -0.012" rpy="0 0 0"/>
      </collision>
    </link>

    <!-- 夹爪关节及 mimic 关系 -->
    <joint name="${prefix}gripper_controller" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000.0" lower="-0.74" upper="0.15" velocity="0"/>
      <parent link="${prefix}gripper_base"/>
      <child link="${prefix}gripper_left3"/>
      <origin xyz="-0.012 0.005 0" rpy="0 0 0"/>
    </joint>

    <joint name="${prefix}gripper_base_to_gripper_left2" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000.0" lower="-0.8" upper="0.5" velocity="0"/>
      <parent link="${prefix}gripper_base"/>
      <child link="${prefix}gripper_left2"/>
      <origin xyz="-0.005 0.027 0" rpy="0 0 0"/>
      <mimic joint="${prefix}gripper_controller" multiplier="1.0" offset="0"/>
    </joint>

    <joint name="${prefix}gripper_left3_to_gripper_left1" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000.0" lower="-0.5" upper="0.5" velocity="0"/>
      <parent link="${prefix}gripper_left3"/>
      <child link="${prefix}gripper_left1"/>
      <origin xyz="-0.027 0.016 0" rpy="0 0 0"/>
      <mimic joint="${prefix}gripper_controller" multiplier="-1.0" offset="0"/>
    </joint>

    <joint name="${prefix}gripper_base_to_gripper_right3" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000.0" lower="-0.15" upper="0.7" velocity="0"/>
      <parent link="${prefix}gripper_base"/>
      <child link="${prefix}gripper_right3"/>
      <origin xyz="0.012 0.005 0" rpy="0 0 0"/>
      <mimic joint="${prefix}gripper_controller" multiplier="-1.0" offset="0"/>
    </joint>

    <joint name="${prefix}gripper_base_to_gripper_right2" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000.0" lower="-0.5" upper="0.8" velocity="0"/>
      <parent link="${prefix}gripper_base"/>
      <child link="${prefix}gripper_right2"/>
      <origin xyz="0.005 0.027 0" rpy="0 0 0"/>
      <mimic joint="${prefix}gripper_controller" multiplier="-1.0" offset="0"/>
    </joint>

    <joint name="${prefix}gripper_right3_to_gripper_right1" type="revolute">
      <axis xyz="0 0 1"/>
      <limit effort="1000.0" lower="-0.5" upper="0.5" velocity="0"/>
      <parent link="${prefix}gripper_right3"/>
      <child link="${prefix}gripper_right1"/>
      <origin xyz="0.027 0.016 0" rpy="0 0 0"/>
      <mimic joint="${prefix}gripper_controller" multiplier="1.0" offset="0"/>
    </joint>

  </xacro:macro>

</robot>