          </material>
        </visual>
      </link>
    </model>

    <!-- 篓子 basket_1：内联圆柱 -->
    <model name="basket_1">
      <static>true</static>
      <pose>4 0 0.215 3.14159265 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.2</radius>
              <length>0.23</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.2</radius>
              <length>0.23</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.6 0.6 0.6 1</ambient>
            <diffuse>0.6 0.6 0.6 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="basket_purple_1">
      <static>true</static>
      <pose>0.2 0.3 0.015 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.15</radius>
              <length>0.03</length>
            </cylinder>
          </geometry>
        </collision>
        <visual name="visual">
          <geometry>
            <cylinder>
              <radius>0.15</radius>
              <length>0.03</length>
            </cylinder>
          </geometry>
          <material>
            <ambient>0.5 0.2 0.5 1</ambient>
            <diffuse>0.5 0.2 0.5 1</diffuse>
            <specular>0.2 0.2 0.2 1</specular>
          </material>
        </visual>
      </link>
    </model>

    <model name="basket_yellow_1">
      <static>true</static>
      <pose>0.2 0 0.015 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.15</radius>
              <length>0.03</length>
